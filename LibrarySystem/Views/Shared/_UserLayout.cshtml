<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Library System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibrarySystem.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="user-navbar">
        <div class="nav-container">
            <a class="nav-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-icon">📚</span>
                <span class="brand-text">Library System</span>
            </a>
            
            <div class="nav-search">
                <input type="text" placeholder="Search books..." class="search-input">
                <button class="search-btn">🔍</button>
            </div>
            
            <div class="nav-menu">
                <a asp-controller="User" asp-action="Profile" class="nav-link">Profile</a>
                <a asp-controller="User" asp-action="BorrowedBooks" class="nav-link">Borrowed Books</a>
                <a asp-controller="User" asp-action="ReturnedBooks" class="nav-link">Returned Books</a>
                <a asp-controller="User" asp-action="TransactionHistory" class="nav-link">Transaction History</a>
                <a asp-controller="User" asp-action="Categories" class="nav-link">Categories</a>
            </div>
            
            <div class="nav-user">
                <a asp-controller="Home" asp-action="Index" class="btn btn-logout">
                    Log Out
                </a>
            </div>
        </div>
    </nav>

    <main class="user-main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
