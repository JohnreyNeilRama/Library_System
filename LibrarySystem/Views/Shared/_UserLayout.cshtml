<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Library System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibrarySystem.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="user-navbar shadow-sm">
        <div class="nav-container">
            <!-- Brand -->
            <a class="nav-brand" asp-controller="Home" asp-action="Index">
                <div class="brand-logo">
                    <i class="bi bi-book-half"></i>
                </div>
                <span class="brand-text">Library<span>System</span></span>
            </a>
            
            <!-- Main Navigation -->
            <div class="nav-menu ms-4">
                <a asp-controller="User" asp-action="Dashboard" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-grid-1x2 me-1"></i> Dashboard
                </a>
                <a asp-controller="User" asp-action="Categories" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Categories" ? "active" : "")">
                    <i class="bi bi-tags me-1"></i> Categories
                </a>
                
                <!-- Activity Dropdown -->
                <div class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="activityDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-activity me-1"></i> My Activity
                    </a>
                    <ul class="dropdown-menu dropdown-menu-dark border-0 shadow" aria-labelledby="activityDropdown">
                        <li><a class="dropdown-item" asp-controller="User" asp-action="BorrowedBooks"><i class="bi bi-journal-arrow-up me-2"></i>Borrowed Books</a></li>
                        <li><a class="dropdown-item" asp-controller="User" asp-action="ReturnedBooks"><i class="bi bi-journal-check me-2"></i>Returned Books</a></li>
                        <li><hr class="dropdown-divider bg-secondary"></li>
                        <li><a class="dropdown-item" asp-controller="User" asp-action="TransactionHistory"><i class="bi bi-clock-history me-2"></i>Transaction History</a></li>
                    </ul>
                </div>
                
                <a asp-controller="User" asp-action="Profile" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")">
                    <i class="bi bi-person me-1"></i> Profile
                </a>
            </div>

            <!-- Search Bar -->
            <div class="nav-search-wrapper ms-auto me-4">
                <div class="nav-search-container">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" placeholder="Search for books, authors..." class="search-input">
                </div>
            </div>
            
            <!-- User Actions -->
            <div class="nav-actions">
                <!-- Notification Bell -->
                <div class="notification-wrapper position-relative">
                    <button class="action-btn" id="notificationBell">
                        <i class="bi bi-bell"></i>
                        <span class="notification-badge">1</span>
                    </button>
                    
                    <!-- Notification Dropdown (remains same logic) -->
                    <div class="notification-dropdown shadow-lg animate-fade-in" id="notificationDropdown">
                        <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-light rounded-top">
                            <h6 class="mb-0 fw-bold text-dark">Notifications</h6>
                            <span class="badge bg-primary rounded-pill">1 New</span>
                        </div>
                        <div class="notification-list">
                            <div class="p-3 border-bottom notification-item">
                                <div class="d-flex gap-3">
                                    <div class="notif-icon bg-warning-subtle text-warning">
                                        <i class="bi bi-exclamation-triangle"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <p class="mb-1 small fw-bold text-dark">Due Date Reminder</p>
                                            <small class="text-muted">Just now</small>
                                        </div>
                                        <p class="mb-0 text-muted x-small">Your book <strong>"The Great Gatsby"</strong> is due in 2 days.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="p-2 text-center border-top">
                            <a href="#" class="small text-decoration-none fw-bold text-primary">View All</a>
                        </div>
                    </div>
                </div>

                <a asp-controller="Home" asp-action="Index" class="logout-link ms-2" title="Log Out">
                    <i class="bi bi-power"></i>
                </a>
            </div>
        </div>
    </nav>

    <main class="user-main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const bell = document.getElementById('notificationBell');
            const dropdown = document.getElementById('notificationDropdown');
            const wrapper = document.querySelector('.notification-wrapper');

            if (bell && dropdown) {
                bell.addEventListener('click', function(e) {
                    e.stopPropagation();
                    const isVisible = dropdown.style.display === 'block';
                    dropdown.style.display = isVisible ? 'none' : 'block';
                });

                document.addEventListener('click', function(e) {
                    if (!wrapper.contains(e.target)) {
                        dropdown.style.display = 'none';
                    }
                });
            }
        });
    </script>
</body>
</html>
