<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibrarySystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibrarySystem.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">
</head>
<body class="account-page">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3 shadow-sm">
            <div class="container">
                <!-- LEFT: LOGO -->
                <a class="nav-brand" asp-controller="Home" asp-action="Index">
                    <div class="brand-logo">
                        <i class="bi bi-book-half"></i>
                    </div>
                    <span class="brand-text">Library<span>System</span></span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navMenu">
                    <ul class="navbar-nav mx-auto nav-links">
                        <li class="nav-item">
                            <a class="nav-link px-4" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-4" href="#">Browse</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-4" href="#">Categories</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-4" href="#">About</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-3 auth-links">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        <a class="btn btn-primary px-4" asp-controller="Account" asp-action="Register">Register</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="flex-fill">
        @RenderBody()
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

