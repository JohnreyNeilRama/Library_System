<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibrarySystem</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibrarySystem.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <nav class="user-navbar">
        <div class="nav-container">
            <a class="nav-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-icon">&#128218;</span>
                <span class="brand-text">Library System</span>
            </a>

            <div class="nav-search">
                <input type="text" placeholder="Search books..." class="search-input">
                <button class="search-btn">&#128269;</button>
            </div>

            <div class="nav-menu">
                <a asp-controller="Admin" asp-action="Index" class="nav-link">Dashboard</a>
                <a asp-controller="Admin" asp-action="ManageBooks" class="nav-link">Borrowed Books</a>
                <a asp-controller="Admin" asp-action="ReturnedBooks" class="nav-link">Returned Books</a>
                <a asp-controller="Admin" asp-action="TransactionHistory" class="nav-link">Transaction History</a>
                <a asp-controller="Admin" asp-action="Categories" class="nav-link">Categories</a>
                <a asp-controller="Reservation" asp-action="Index" class="nav-link">Reservation</a>
            </div>

            <div class="nav-user">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn btn-logout">
                        Log Out
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <main class="user-main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


