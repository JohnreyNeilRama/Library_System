<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibrarySystem Admin</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibrarySystem.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    @{
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    }

    <div class="admin-wrapper">
        <!-- Sidebar -->
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="admin-sidebar-header">
                <i class="bi bi-book-half admin-sidebar-icon"></i>
                <h4>Admin Panel</h4>
            </div>

            <div class="admin-sidebar-nav">
                <!-- Dashboard -->
                <p class="nav-section-label">Dashboard</p>
                <ul class="p-0 m-0">
                    <li class="admin-nav-item">
                        <a asp-controller="Admin" asp-action="Dashboard" class="admin-nav-link @(currentAction == "Dashboard" && currentController == "Admin" ? "active" : "")">
                            <i class="bi bi-grid-1x2-fill"></i> Dashboard
                        </a>
                    </li>
                </ul>

                <!-- Book Management -->
                <p class="nav-section-label">Book Management</p>
                <ul class="p-0 m-0">
                    <li class="admin-nav-item">
                        <a href="#" class="admin-nav-link">
                            <i class="bi bi-journals"></i> All Books
                        </a>
                    </li>
                    <li class="admin-nav-item">
                        <a href="#" class="admin-nav-link">
                            <i class="bi bi-plus-circle"></i> Add Book
                        </a>
                    </li>
                    <li class="admin-nav-item">
                        <a asp-controller="Admin" asp-action="Categories" class="admin-nav-link @(currentAction == "Categories" ? "active" : "")">
                            <i class="bi bi-tags"></i> Categories
                        </a>
                    </li>
                </ul>

                <!-- User Management -->
                <p class="nav-section-label">User Management</p>
                <ul class="p-0 m-0">
                    <li class="admin-nav-item">
                        <a href="#" class="admin-nav-link">
                            <i class="bi bi-people"></i> Users / Students
                        </a>
                    </li>
                </ul>

                <!-- Transactions -->
                <p class="nav-section-label">Transactions</p>
                <ul class="p-0 m-0">
                    <li class="admin-nav-item">
                        <a asp-controller="Admin" asp-action="ManageBooks" class="admin-nav-link @(currentAction == "ManageBooks" ? "active" : "")">
                            <i class="bi bi-bookmark-dash"></i> Borrowed Books
                        </a>
                    </li>
                    <li class="admin-nav-item">
                        <a asp-controller="Admin" asp-action="ReturnedBooks" class="admin-nav-link @(currentAction == "ReturnedBooks" ? "active" : "")">
                            <i class="bi bi-bookmark-check"></i> Returned Books
                        </a>
                    </li>
                    <li class="admin-nav-item">
                        <a asp-controller="Admin" asp-action="TransactionHistory" class="admin-nav-link @(currentAction == "TransactionHistory" ? "active" : "")">
                            <i class="bi bi-clock-history"></i> Transaction History
                        </a>
                    </li>
                    <li class="admin-nav-item">
                        <a asp-controller="Reservation" asp-action="Index" class="admin-nav-link @(currentController == "Reservation" ? "active" : "")">
                            <i class="bi bi-calendar-check"></i> Reservations
                        </a>
                    </li>
                </ul>

                <!-- Settings -->
                <p class="nav-section-label">Settings</p>
                <ul class="p-0 m-0 pb-4">
                    <li class="admin-nav-item">
                        <a href="#" class="admin-nav-link">
                            <i class="bi bi-gear"></i> Settings
                        </a>
                    </li>
                </ul>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="admin-main">
            <!-- Top Navbar -->
            <header class="admin-top-navbar">
                <div class="top-navbar-left">
                    <button class="mobile-toggle" id="sidebarToggle">
                        <i class="bi bi-list"></i>
                    </button>
                    
                    <div class="admin-search-form">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Search anything...">
                    </div>
                </div>

                <div class="top-navbar-right">
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="btn btn-danger btn-sm px-3 rounded-pill fw-medium shadow-sm">
                            <i class="bi bi-box-arrow-right me-1"></i> Log Out
                        </button>
                    </form>
                </div>
            </header>

            <!-- Page Content -->
            <main class="admin-content-body">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Mobile Overlay -->
    <div class="modal-overlay" id="sidebarOverlay" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1025;"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.getElementById('sidebarToggle')?.addEventListener('click', function() {
            document.getElementById('adminSidebar').classList.toggle('show');
            document.getElementById('sidebarOverlay').style.display = 'block';
        });

        document.getElementById('sidebarOverlay')?.addEventListener('click', function() {
            document.getElementById('adminSidebar').classList.remove('show');
            this.style.display = 'none';
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


