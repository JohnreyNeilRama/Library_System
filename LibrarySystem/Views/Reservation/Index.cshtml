                        <th scope="col" style="min-width:200px">Book Title</th>
                        <th scope="col" style="width:130px">Request Date</th>
                        <th scope="col" style="width:120px">Status</th>
                        <th scope="col" style="width:150px">Actions</th>
                    </tr>
                </thead>
