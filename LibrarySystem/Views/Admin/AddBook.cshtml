@model LibrarySystem.Controllers.AdminBookViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Book";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h4 class="fw-bold mb-1">Add Book</h4>
        <p class="text-muted mb-0 small">Create a new catalog entry and set its starting inventory.</p>
    </div>
    <a asp-controller="Admin" asp-action="AllBooks" class="btn btn-light btn-sm">
        <i class="bi bi-arrow-left"></i> Back to All Books
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form asp-controller="Admin" asp-action="AddBook" method="post" id="addBookPageForm">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-4">
                <div class="col-12 col-lg-8">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label text-muted small fw-bold text-uppercase">Book Title</label>
                        <input asp-for="Title" class="form-control" required />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Author" class="form-label text-muted small fw-bold text-uppercase">Author</label>
                        <input asp-for="Author" class="form-control" required />
                        <span asp-validation-for="Author" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ISBN" class="form-label text-muted small fw-bold text-uppercase">ISBN</label>
                            <input asp-for="ISBN" class="form-control" />
                            <span asp-validation-for="ISBN" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="PublishedYear" class="form-label text-muted small fw-bold text-uppercase">Published Year</label>
                            <input asp-for="PublishedYear" type="number" min="0" max="2100" class="form-control" />
                            <span asp-validation-for="PublishedYear" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label text-muted small fw-bold text-uppercase">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-12 col-lg-4">
                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label text-muted small fw-bold text-uppercase">Category</label>
                        <select asp-for="CategoryId" class="form-select" required disabled="@(!Model.Categories.Any())">
                            <option value="">Select category</option>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label asp-for="AvailableCopies" class="form-label text-muted small fw-bold text-uppercase">Available</label>
                            <input asp-for="AvailableCopies" type="number" min="0" class="form-control" required />
                            <span asp-validation-for="AvailableCopies" class="text-danger small"></span>
                        </div>
                        <div class="col-6 mb-3">
                            <label asp-for="TotalCopies" class="form-label text-muted small fw-bold text-uppercase">Total</label>
                            <input asp-for="TotalCopies" type="number" min="1" class="form-control" required />
                            <span asp-validation-for="TotalCopies" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CoverImageUrl" class="form-label text-muted small fw-bold text-uppercase">Cover Image URL</label>
                        <input asp-for="CoverImageUrl" class="form-control" />
                        <span asp-validation-for="CoverImageUrl" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 border-top pt-4 mt-2">
                <a asp-controller="Admin" asp-action="AllBooks" class="btn btn-light">Cancel</a>
                <button type="submit" class="btn btn-primary" disabled="@(!Model.Categories.Any())">
                    <i class="bi bi-plus-lg me-1"></i> Add Book
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('addBookPageForm')?.addEventListener('submit', function () {
            const available = document.getElementById('AvailableCopies');
            const total = document.getElementById('TotalCopies');

            if (available && total && Number(total.value) < Number(available.value)) {
                total.value = available.value;
            }
        });
    </script>
}
