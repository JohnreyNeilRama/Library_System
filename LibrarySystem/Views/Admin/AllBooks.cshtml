@model LibrarySystem.Controllers.AdminAllBooksViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "All Books";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h4 class="fw-bold mb-1">All Books</h4>
        <p class="text-muted mb-0 small">Manage all books in the library system.</p>
    </div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#globalAddBookModal">
        <i class="bi bi-plus-lg"></i> Add New Book
    </button>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="p-3 border-bottom bg-light">
            <form asp-controller="Admin" asp-action="AllBooks" method="get" class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                <div class="input-group" style="max-width: 300px;">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" value="@Model.Search" class="form-control border-start-0 ps-0" placeholder="Search by title, author, ISBN...">
                </div>
                <div class="d-flex gap-2">
                    <select class="form-select form-select-sm" name="category" style="min-width: 180px;">
                        <option value="">All Categories</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.Id" selected="@(Model.SelectedCategory == category.Id)">@category.Name</option>
                        }
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm">Apply</button>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4" style="width: 40px;">#</th>
                        <th>Book Title</th>
                        <th>Author</th>
                        <th>Category</th>
                        <th>Copies</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Books.Any())
                    {
                        var rowNumber = 1;
                        foreach (var book in Model.Books)
                        {
                            var category = Model.Categories.FirstOrDefault(c => c.Id == book.CategoryId);
                            var status = GetBookStatus(book.AvailableCopies);
                            <tr>
                                <td class="ps-4 text-muted">@rowNumber</td>
                                <td>
                                    <div class="fw-medium text-dark">@book.Title</div>
                                    <div class="small text-muted">@book.ISBN</div>
                                </td>
                                <td class="text-muted">@book.Author</td>
                                <td><span class="badge bg-light text-secondary border">@(category?.Name ?? book.CategoryId)</span></td>
                                <td class="fw-bold">@book.AvailableCopies/@book.TotalCopies</td>
                                <td>@Html.Raw(BookStatusBadge(status))</td>
                                <td class="text-end pe-4">
                                    <a asp-controller="Admin" asp-action="EditBook" asp-route-id="@book.Id" class="btn btn-sm btn-light text-primary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-controller="Admin"
                                          asp-action="DeleteBook"
                                          method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('Delete @book.Title? This cannot be undone.');">
                                        <input type="hidden" name="id" value="@book.Id" />
                                        <button type="submit" class="btn btn-sm btn-light text-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            rowNumber++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No books found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="p-3 border-top d-flex justify-content-between align-items-center text-muted small">
            <div>Showing <span class="fw-medium text-dark">@Model.Books.Count</span> entries</div>
        </div>
    </div>
</div>

@functions {
    private static string GetBookStatus(int availableCopies)
    {
        if (availableCopies <= 0) return "Out of Stock";
        if (availableCopies <= 2) return "Low Stock";
        return "Available";
    }

    private static string BookStatusBadge(string status)
    {
        return status switch
        {
            "Out of Stock" => "<span class=\"badge bg-danger bg-opacity-10 text-danger px-2 py-1\">Out of Stock</span>",
            "Low Stock" => "<span class=\"badge bg-warning bg-opacity-10 text-warning px-2 py-1\">Low Stock</span>",
            _ => "<span class=\"badge bg-success bg-opacity-10 text-success px-2 py-1\">Available</span>"
        };
    }
}
