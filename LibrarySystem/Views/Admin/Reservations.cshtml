@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Reservation";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h4 class="fw-bold mb-1">Reservation Management</h4>
        <p class="text-muted mb-0 small">Approve or reject user reservation requests.</p>
    </div>
    <div class="d-flex gap-2">
        <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i> 2 Pending
        </span>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <!-- Search Bar -->
        <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-light">
            <div class="input-group" style="max-width: 350px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="reservationSearch" class="form-control border-start-0 ps-0" placeholder="Search user or book...">
            </div>
            <div>
                <select class="form-select form-select-sm" id="statusFilter" style="min-width: 140px;">
                    <option value="all">All Status</option>
                    <option value="pending">Pending</option>
                    <option value="approved">Approved</option>
                    <option value="rejected">Rejected</option>
                </select>
            </div>
        </div>

        <!-- Table -->
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">#</th>
                        <th>User</th>
                        <th>Book Title</th>
                        <th>Request Date</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody id="reservationTableBody">
                    <tr data-status="pending">
                        <td class="ps-4">1</td>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 35px; height: 35px;">
                                    S
                                </div>
                                <span class="fw-bold text-dark">Sarah Johnson</span>
                            </div>
                        </td>
                        <td class="text-muted small">The Silent Patient</td>
                        <td class="text-muted small">2026-04-25</td>
                        <td><span class="badge bg-warning bg-opacity-10 text-warning px-2 py-1"><i class="bi bi-hourglass-split me-1"></i>Pending</span></td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-primary review-btn" data-id="1" data-bs-toggle="modal" data-bs-target="#reviewReservationModal">Review Request</button>
                        </td>
                    </tr>
                    <tr data-status="pending">
                        <td class="ps-4">2</td>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 35px; height: 35px;">
                                    M
                                </div>
                                <span class="fw-bold text-dark">Michael Chen</span>
                            </div>
                        </td>
                        <td class="text-muted small">Atomic Habits</td>
                        <td class="text-muted small">2026-04-24</td>
                        <td><span class="badge bg-warning bg-opacity-10 text-warning px-2 py-1"><i class="bi bi-hourglass-split me-1"></i>Pending</span></td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-primary review-btn" data-id="2" data-bs-toggle="modal" data-bs-target="#reviewReservationModal">Review Request</button>
                        </td>
                    </tr>
                    <tr data-status="approved">
                        <td class="ps-4">3</td>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 35px; height: 35px;">
                                    E
                                </div>
                                <span class="fw-bold text-dark">Emily Rodriguez</span>
                            </div>
                        </td>
                        <td class="text-muted small">Project Hail Mary</td>
                        <td class="text-muted small">2026-04-23</td>
                        <td><span class="badge bg-success bg-opacity-10 text-success px-2 py-1"><i class="bi bi-check-circle me-1"></i>Approved</span></td>
                        <td class="text-end pe-4">
                            <span class="text-muted small"><i class="bi bi-check-lg me-1"></i>Approved</span>
                        </td>
                    </tr>
                    <tr data-status="rejected">
                        <td class="ps-4">4</td>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 35px; height: 35px;">
                                    D
                                </div>
                                <span class="fw-bold text-dark">David Kim</span>
                            </div>
                        </td>
                        <td class="text-muted small">The Midnight Library</td>
                        <td class="text-muted small">2026-04-20</td>
                        <td><span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1"><i class="bi bi-x-circle me-1"></i>Rejected</span></td>
                        <td class="text-end pe-4">
                            <span class="text-muted small"><i class="bi bi-x-lg me-1"></i>Rejected</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="p-3 border-top d-flex justify-content-between align-items-center text-muted small bg-white rounded-bottom">
            <div>Showing <span class="fw-medium text-dark">1</span> to <span class="fw-medium text-dark">4</span> entries</div>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">Next</a></li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- Review Reservation Modal -->
<div class="modal fade" id="reviewReservationModal" tabindex="-1" aria-labelledby="reviewReservationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light border-bottom-0">
                <h5 class="modal-title fw-bold" id="reviewReservationModalLabel"><i class="bi bi-calendar-check me-2 text-primary"></i>Review Reservation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="modalReservationId">
                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold text-uppercase">Student / User</label>
                    <input type="text" class="form-control bg-light fw-bold" id="modalUserName" readonly>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold text-uppercase">Book Title</label>
                    <input type="text" class="form-control bg-light fw-bold" id="modalBookTitle" readonly>
                </div>
                <div class="row">
                    <div class="col-6 mb-4">
                        <label class="form-label text-muted small fw-bold text-uppercase">Request Date</label>
                        <input type="text" class="form-control bg-light" id="modalRequestDate" readonly>
                    </div>
                    <div class="col-6 mb-4">
                        <label class="form-label text-muted small fw-bold text-uppercase text-primary">Set Due Date</label>
                        <input type="date" class="form-control border-primary shadow-sm" id="modalDueDate" required>
                    </div>
                </div>
                <hr class="text-muted opacity-25">
                <p class="small text-muted mb-3"><i class="bi bi-info-circle me-1"></i>Please specify a strict due date before approving this reservation request.</p>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-success flex-grow-1" id="modalApproveBtn">
                        <i class="bi bi-check-circle me-1"></i> Approve Request
                    </button>
                    <button type="button" class="btn btn-outline-danger flex-grow-1" id="modalRejectBtn">
                        <i class="bi bi-x-circle me-1"></i> Decline Request
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('reservationSearch');
            const statusFilter = document.getElementById('statusFilter');
            const rows = document.querySelectorAll('#reservationTableBody tr');

            function filterTable() {
                const searchTerm = searchInput.value.toLowerCase();
                const statusValue = statusFilter.value;

                rows.forEach(row => {
                    const user = row.cells[1].textContent.toLowerCase();
                    const book = row.cells[2].textContent.toLowerCase();
                    const status = row.getAttribute('data-status');

                    const matchSearch = user.includes(searchTerm) || book.includes(searchTerm);
                    const matchStatus = statusValue === 'all' || status === statusValue;

                    row.style.display = (matchSearch && matchStatus) ? '' : 'none';
                });
            }

            searchInput.addEventListener('input', filterTable);
            statusFilter.addEventListener('change', filterTable);

            // Review button handler to open modal
            document.querySelectorAll('.review-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const row = this.closest('tr');
                    const id = this.getAttribute('data-id');
                    
                    // Extract data from the row
                    const user = row.querySelector('td:nth-child(2) .fw-bold').textContent.trim();
                    const book = row.querySelector('td:nth-child(3)').textContent.trim();
                    const date = row.querySelector('td:nth-child(4)').textContent.trim();
                    
                    // Populate modal
                    document.getElementById('modalReservationId').value = id;
                    document.getElementById('modalUserName').value = user;
                    document.getElementById('modalBookTitle').value = book;
                    document.getElementById('modalRequestDate').value = date;
                    
                    // Suggest a default due date (7 days from now)
                    const defaultDue = new Date();
                    defaultDue.setDate(defaultDue.getDate() + 7);
                    document.getElementById('modalDueDate').value = defaultDue.toISOString().split('T')[0];
                });
            });

            // Modal Approve logic
            document.getElementById('modalApproveBtn').addEventListener('click', function() {
                const id = document.getElementById('modalReservationId').value;
                const dueDate = document.getElementById('modalDueDate').value;
                
                if(!dueDate) {
                    alert('Please set a valid due date before approving.');
                    return;
                }
                
                const btn = document.querySelector(`.review-btn[data-id="${id}"]`);
                if(btn) {
                    const row = btn.closest('tr');
                    const statusBadge = row.querySelector('td:nth-child(5)');
                    
                    // Update Status Badge and add Due Date subtext
                    statusBadge.innerHTML = `
                        <span class="badge bg-success bg-opacity-10 text-success px-2 py-1"><i class="bi bi-check-circle me-1"></i>Approved</span>
                        <div class="small fw-bold text-muted mt-1"><i class="bi bi-calendar-event me-1"></i>Due: ${dueDate}</div>
                    `;
                    row.setAttribute('data-status', 'approved');
                    
                    // Update Action column
                    const actionCell = row.querySelector('td:last-child');
                    actionCell.innerHTML = '<span class="text-muted small"><i class="bi bi-check-lg me-1"></i>Approved</span>';
                }
                
                bootstrap.Modal.getInstance(document.getElementById('reviewReservationModal')).hide();
            });

            // Modal Reject logic
            document.getElementById('modalRejectBtn').addEventListener('click', function() {
                const id = document.getElementById('modalReservationId').value;
                const btn = document.querySelector(`.review-btn[data-id="${id}"]`);
                
                if(btn) {
                    const row = btn.closest('tr');
                    const statusBadge = row.querySelector('td:nth-child(5)');
                    
                    statusBadge.innerHTML = '<span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1"><i class="bi bi-x-circle me-1"></i>Rejected</span>';
                    row.setAttribute('data-status', 'rejected');
                    
                    const actionCell = row.querySelector('td:last-child');
                    actionCell.innerHTML = '<span class="text-muted small"><i class="bi bi-x-lg me-1"></i>Rejected</span>';
                }
                
                bootstrap.Modal.getInstance(document.getElementById('reviewReservationModal')).hide();
            });
        });
    </script>
}
