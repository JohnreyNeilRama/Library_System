@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Transaction History";
}

<div class="px-3 px-lg-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Transaction History</h1>
            <p class="text-muted mb-0">View and manage all borrow and return transactions</p>
        </div>
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="row g-3 align-items-center">
                    <div class="col-12 col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#6c757d" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                            </svg>
                        </span>
                        <input type="text" class="form-control border-start-0 shadow-none" placeholder="Search title or author..." id="searchInput" />
                        <button class="btn btn-primary" type="button" id="searchButton">
                            Search
                        </button>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <select class="form-select" id="typeFilter">
                        <option value="all">All Transaction Types</option>
                        <option value="Borrowed">Borrowed</option>
                        <option value="Returned">Returned</option>
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <select class="form-select" id="statusFilter">
                        <option value="all">All Status</option>
                        <option value="On Time">On Time</option>
                        <option value="Due Soon">Due Soon</option>
                        <option value="Overdue">Overdue</option>
                        <option value="Returned Late">Returned Late</option>
                    </select>
                </div>
                <div class="col-12 col-md-auto">
                    <button class="btn btn-primary w-100" id="applyFilters">
                        Apply Filters
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Transactions Table -->
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="ps-4" style="width:60px">#</th>
                        <th scope="col" style="min-width:200px">Title</th>
                        <th scope="col" style="width:100px">Type</th>
                        <th scope="col" style="width:140px">Borrower</th>
                        <th scope="col" style="width:120px">Borrow Date</th>
                        <th scope="col" style="width:120px">Return Date</th>
                        <th scope="col" style="width:110px">Status</th>
                    </tr>
                </thead>
                <tbody id="transactionTableBody">
                    <tr data-type="Borrowed" data-status="On Time">
                        <td class="ps-4 fw-medium text-muted">1</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light p-2 rounded me-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#6c757d" viewBox="0 0 16 16">
                                        <path d="M3.5.5A.5.5 0 0 1 4 1h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.5.5H4a.5.5 0 0 1-.5-.5v-2zM4 3h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/>
                                    </svg>
                                </div>
                                <span class="fw-medium">The Great Gatsby</span>
                            </div>
                        </td>
                        <td><span class="badge bg-primary">Borrowed</span></td>
                        <td>John Doe</td>
                        <td>2026-04-16</td>
                        <td><span class="text-muted">-</span></td>
                        <td><span class="badge bg-success">On Time</span></td>
                    </tr>
                    <tr data-type="Borrowed" data-status="Due Soon">
                        <td class="ps-4 fw-medium text-muted">2</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light p-2 rounded me-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#6c757d" viewBox="0 0 16 16">
                                        <path d="M3.5.5A.5.5 0 0 1 4 1h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.5.5H4a.5.5 0 0 1-.5-.5v-2zM4 3h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/>
                                    </svg>
                                </div>
                                <span class="fw-medium">To Kill a Mockingbird</span>
                            </div>
                        </td>
                        <td><span class="badge bg-primary">Borrowed</span></td>
                        <td>Jane Smith</td>
                        <td>2026-04-11</td>
                        <td><span class="text-muted">-</span></td>
                        <td><span class="badge bg-warning text-dark">Due Soon</span></td>
                    </tr>
                    <tr data-type="Borrowed" data-status="Overdue">
                        <td class="ps-4 fw-medium text-muted">3</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light p-2 rounded me-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#6c757d" viewBox="0 0 16 16">
                                        <path d="M3.5.5A.5.5 0 0 1 4 1h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.5.5H4a.5.5 0 0 1-.5-.5v-2zM4 3h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/>
                                    </svg>
                                </div>
                                <span class="fw-medium">1984</span>
                            </div>
                        </td>
                        <td><span class="badge bg-primary">Borrowed</span></td>
                        <td>Bob Wilson</td>
                        <td>2026-04-06</td>
                        <td><span class="text-muted">-</span></td>
                        <td><span class="badge bg-danger">Overdue</span></td>
                    </tr>
                    <tr data-type="Returned" data-status="On Time">
                        <td class="ps-4 fw-medium text-muted">4</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light p-2 rounded me-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#6c757d" viewBox="0 0 16 16">
                                        <path d="M3.5.5A.5.5 0 0 1 4 1h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.5.5H4a.5.5 0 0 1-.5-.5v-2zM4 3h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/>
                                    </svg>
                                </div>
                                <span class="fw-medium">The Alchemist</span>
                            </div>
                        </td>
                        <td><span class="badge bg-secondary">Returned</span></td>
                        <td>John Doe</td>
                        <td>2026-03-26</td>
                        <td>2026-04-21</td>
                        <td><span class="badge bg-success">On Time</span></td>
                    </tr>
                    <tr data-type="Returned" data-status="On Time">
                        <td class="ps-4 fw-medium text-muted">5</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light p-2 rounded me-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#6c757d" viewBox="0 0 16 16">
                                        <path d="M3.5.5A.5.5 0 0 1 4 1h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.5.5H4a.5.5 0 0 1-.5-.5v-2zM4 3h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/>
                                    </svg>
                                </div>
                                <span class="fw-medium">The Hobbit</span>
                            </div>
                        </td>
                        <td><span class="badge bg-secondary">Returned</span></td>
                        <td>Jane Smith</td>
                        <td>2026-04-01</td>
                        <td>2026-04-23</td>
                        <td><span class="badge bg-success">On Time</span></td>
                    </tr>
                    <tr data-type="Returned" data-status="Returned Late">
                        <td class="ps-4 fw-medium text-muted">6</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light p-2 rounded me-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#6c757d" viewBox="0 0 16 16">
                                        <path d="M3.5.5A.5.5 0 0 1 4 1h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.5.5H4a.5.5 0 0 1-.5-.5v-2zM4 3h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/>
                                    </svg>
                                </div>
                                <span class="fw-medium">Dune</span>
                            </div>
                        </td>
                        <td><span class="badge bg-secondary">Returned</span></td>
                        <td>Bob Wilson</td>
                        <td>2026-03-31</td>
                        <td>2026-04-25</td>
                        <td><span class="badge bg-warning text-dark">Returned Late</span></td>
                    </tr>
                    <tr data-type="Returned" data-status="On Time">
                        <td class="ps-4 fw-medium text-muted">7</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light p-2 rounded me-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#6c757d" viewBox="0 0 16 16">
                                        <path d="M3.5.5A.5.5 0 0 1 4 1h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.5.5H4a.5.5 0 0 1-.5-.5v-2zM4 3h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/>
                                    </svg>
                                </div>
                                <span class="fw-medium">Foundation</span>
                            </div>
                        </td>
                        <td><span class="badge bg-secondary">Returned</span></td>
                        <td>Alice Brown</td>
                        <td>2026-03-18</td>
                        <td>2026-04-16</td>
                        <td><span class="badge bg-success">On Time</span></td>
                    </tr>
                    <tr data-type="Borrowed" data-status="On Time">
                        <td class="ps-4 fw-medium text-muted">8</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light p-2 rounded me-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#6c757d" viewBox="0 0 16 16">
                                        <path d="M3.5.5A.5.5 0 0 1 4 1h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.5.5H4a.5.5 0 0 1-.5-.5v-2zM4 3h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/>
                                    </svg>
                                </div>
                                <span class="fw-medium">Pride and Prejudice</span>
                            </div>
                        </td>
                        <td><span class="badge bg-primary">Borrowed</span></td>
                        <td>Alice Brown</td>
                        <td>2026-04-21</td>
                        <td><span class="text-muted">-</span></td>
                        <td><span class="badge bg-success">On Time</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
            <li class="page-item active"><a class="page-link" href="#">1</a></li>
            <li class="page-item"><a class="page-link" href="#">2</a></li>
            <li class="page-item"><a class="page-link" href="#">3</a></li>
            <li class="page-item"><a class="page-link" href="#">Next</a></li>
        </ul>
    </nav>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('searchInput');
        const typeFilter = document.getElementById('typeFilter');
        const statusFilter = document.getElementById('statusFilter');
        const rows = document.querySelectorAll('#transactionTableBody tr');

        function filterTable() {
            const searchTerm = searchInput.value.toLowerCase();
            const typeValue = typeFilter.value;
            const statusValue = statusFilter.value;

            rows.forEach(row => {
                const title = row.cells[1].textContent.toLowerCase();
                const type = row.getAttribute('data-type');
                const status = row.getAttribute('data-status');

                const matchSearch = title.includes(searchTerm);
                const matchType = typeValue === 'all' || type === typeValue;
                const matchStatus = statusValue === 'all' || status === statusValue;

                row.style.display = (matchSearch && matchType && matchStatus) ? '' : 'none';
            });
        }

        searchInput.addEventListener('input', filterTable);
        typeFilter.addEventListener('change', filterTable);
        statusFilter.addEventListener('change', filterTable);
        document.getElementById('applyFilters').addEventListener('click', filterTable);
        document.getElementById('searchButton').addEventListener('click', filterTable);
    });
</script>