@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Borrowed Books";
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center flex-wrap gap-3">
        <h5 class="mb-0 fw-bold">Borrowed Books Management</h5>
        <div class="d-flex gap-2 flex-wrap">
            <input type="text" class="form-control form-control-sm" placeholder="Search books..." style="min-width:280px" />
            <select class="form-select form-select-sm" style="width:auto">
                <option>All Status</option>
                <option>On Time</option>
                <option>Due Soon</option>
                <option>Overdue</option>
            </select>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>#</th>
                <th>Title</th>
                <th>Author</th>
                <th>Borrower</th>
                <th>Borrow Date</th>
                <th>Due Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>1</td>
                <td><strong>The Great Gatsby</strong></td>
                <td>F. Scott Fitzgerald</td>
                <td>John Doe</td>
                <td>2026-04-16</td>
                <td>2026-05-04</td>
                <td><span class="badge bg-success rounded-pill">On Time</span></td>
                <td>
                    <button class="btn btn-sm btn-outline-primary">Edit</button>
                    <button class="btn btn-sm btn-outline-danger">Return</button>
                </td>
            </tr>
            <tr>
                <td>2</td>
                <td><strong>To Kill a Mockingbird</strong></td>
                <td>Harper Lee</td>
                <td>Jane Smith</td>
                <td>2026-04-11</td>
                <td>2026-04-28</td>
                <td><span class="badge bg-warning rounded-pill text-dark">Due Soon</span></td>
                <td>
                    <button class="btn btn-sm btn-outline-primary">Edit</button>
                    <button class="btn btn-sm btn-outline-danger">Return</button>
                </td>
            </tr>
            <tr>
                <td>3</td>
                <td><strong>1984</strong></td>
                <td>George Orwell</td>
                <td>Bob Wilson</td>
                <td>2026-04-06</td>
                <td>2026-04-23</td>
                <td><span class="badge bg-danger rounded-pill">Overdue</span></td>
                <td>
                    <button class="btn btn-sm btn-outline-primary">Edit</button>
                    <button class="btn btn-sm btn-outline-danger">Return</button>
                </td>
            </tr>
            <tr>
                <td>4</td>
                <td><strong>Pride and Prejudice</strong></td>
                <td>Jane Austen</td>
                <td>Alice Brown</td>
                <td>2026-04-21</td>
                <td>2026-05-10</td>
                <td><span class="badge bg-success rounded-pill">On Time</span></td>
                <td>
                    <button class="btn btn-sm btn-outline-primary">Edit</button>
                    <button class="btn btn-sm btn-outline-danger">Return</button>
                </td>
            </tr>
            <tr>
                <td>5</td>
                <td><strong>The Catcher in the Rye</strong></td>
                <td>J.D. Salinger</td>
                <td>Charlie Green</td>
                <td>2026-04-18</td>
                <td>2026-04-29</td>
                <td><span class="badge bg-warning rounded-pill text-dark">Due Soon</span></td>
                <td>
                    <button class="btn btn-sm btn-outline-primary">Edit</button>
                    <button class="btn btn-sm btn-outline-danger">Return</button>
                </td>
            </tr>
        </tbody>
    </table>
</div>

<nav class="mt-4">
    <ul class="pagination justify-content-center">
        <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
        <li class="page-item active"><a class="page-link" href="#">1</a></li>
        <li class="page-item"><a class="page-link" href="#">2</a></li>
        <li class="page-item"><a class="page-link" href="#">3</a></li>
        <li class="page-item"><a class="page-link" href="#">Next</a></li>
    </ul>
</nav>