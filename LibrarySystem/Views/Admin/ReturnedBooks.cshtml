@model LibrarySystem.Controllers.AdminReturnedBooksViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Returned Books";

    var onTime = Model.Transactions.Count(t => t.Status == "On Time");
    var late = Model.Transactions.Count(t => t.Status == "Returned Late");
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h4 class="fw-bold mb-1">Returned Books</h4>
        <p class="text-muted mb-0 small">View the history of all successfully returned books.</p>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <div class="row g-4 text-center">
            <div class="col-4 border-end">
                <div class="text-muted small fw-bold text-uppercase mb-1">Total Returns</div>
                <h3 class="fw-bold text-dark mb-0">@Model.Transactions.Count</h3>
            </div>
            <div class="col-4 border-end">
                <div class="text-muted small fw-bold text-uppercase mb-1">Returned On Time</div>
                <h3 class="fw-bold text-success mb-0">@onTime</h3>
            </div>
            <div class="col-4">
                <div class="text-muted small fw-bold text-uppercase mb-1">Returned Late</div>
                <h3 class="fw-bold text-warning mb-0">@late</h3>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-light">
            <div class="input-group" style="max-width: 350px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="returnedSearchInput" class="form-control border-start-0 ps-0" placeholder="Search title or borrower...">
            </div>
            <div class="d-flex gap-2">
                <input type="date" id="returnedDateFilter" class="form-control form-control-sm text-muted" style="min-width: 140px;">
                <select class="form-select form-select-sm" id="returnedStatusFilter" style="min-width: 140px;">
                    <option value="all">All Status</option>
                    <option value="On Time">On Time</option>
                    <option value="Returned Late">Returned Late</option>
                </select>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">#</th>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Borrower</th>
                        <th>Borrow Date</th>
                        <th>Return Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody id="returnedBooksTableBody">
                    @if (Model.Transactions.Any())
                    {
                        var rowNumber = 1;
                        foreach (var transaction in Model.Transactions.OrderByDescending(t => t.ReturnDate))
                        {
                            var book = Model.Books.FirstOrDefault(b => b.Id == transaction.BookId);
                            var user = Model.Users.FirstOrDefault(u => u.Id == transaction.UserId);
                            <tr data-status="@transaction.Status" data-return-date="@transaction.ReturnDate?.ToString("yyyy-MM-dd")" data-search="@($"{book?.Title} {book?.Author} {user?.FullName}".ToLowerInvariant())">
                                <td class="ps-4">@rowNumber</td>
                                <td><div class="fw-bold text-dark">@(book?.Title ?? "Unknown book")</div></td>
                                <td class="text-muted small">@(book?.Author ?? "Unknown")</td>
                                <td>@(user?.FullName ?? "Unknown user")</td>
                                <td class="text-muted small">@transaction.BorrowDate.ToString("yyyy-MM-dd")</td>
                                <td class="text-muted small">@transaction.ReturnDate?.ToString("yyyy-MM-dd")</td>
                                <td>@Html.Raw(ReturnStatusBadge(transaction.Status))</td>
                            </tr>
                            rowNumber++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No returned books yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="p-3 border-top d-flex justify-content-between align-items-center text-muted small bg-white rounded-bottom">
            <div>Showing <span class="fw-medium text-dark">@Model.Transactions.Count</span> entries</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('returnedSearchInput');
            const dateFilter = document.getElementById('returnedDateFilter');
            const statusFilter = document.getElementById('returnedStatusFilter');
            const rows = document.querySelectorAll('#returnedBooksTableBody tr[data-status]');

            function filterRows() {
                const searchTerm = searchInput.value.toLowerCase();
                const selectedDate = dateFilter.value;
                const selectedStatus = statusFilter.value;

                rows.forEach(row => {
                    const matchesSearch = row.getAttribute('data-search').includes(searchTerm);
                    const matchesDate = !selectedDate || row.getAttribute('data-return-date') === selectedDate;
                    const matchesStatus = selectedStatus === 'all' || row.getAttribute('data-status') === selectedStatus;
                    row.style.display = matchesSearch && matchesDate && matchesStatus ? '' : 'none';
                });
            }

            searchInput.addEventListener('input', filterRows);
            dateFilter.addEventListener('change', filterRows);
            statusFilter.addEventListener('change', filterRows);
        });
    </script>
}

@functions {
    private static string ReturnStatusBadge(string status)
    {
        return status == "Returned Late"
            ? "<span class=\"badge bg-warning bg-opacity-10 text-warning px-2 py-1\"><i class=\"bi bi-exclamation-triangle me-1\"></i>Returned Late</span>"
            : "<span class=\"badge bg-success bg-opacity-10 text-success px-2 py-1\"><i class=\"bi bi-check-circle me-1\"></i>On Time</span>";
    }
}
