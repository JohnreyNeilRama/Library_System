@model LibrarySystem.Controllers.AdminDashboardViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Dashboard";

    var lowStockBooks = Model.Books.Where(b => b.AvailableCopies > 0 && b.AvailableCopies <= 2).ToList();
    var alertCount = (Model.OverdueBooks > 0 ? 1 : 0) + (lowStockBooks.Any() ? 1 : 0);
}

<link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />

<div class="dashboard-header">
    <h2>Welcome, Admin</h2>
    <p>Here's an overview of your system activity</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon books"><i class="bi bi-book"></i></div>
            <h3>@Model.TotalBooks.ToString("N0")</h3>
            <p>Total Books</p>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon users"><i class="bi bi-people"></i></div>
            <h3>@Model.TotalUsers.ToString("N0")</h3>
            <p>Total Users</p>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon borrowed"><i class="bi bi-journal-arrow-up"></i></div>
            <h3>@Model.ActiveBorrows.ToString("N0")</h3>
            <p>Borrowed Books</p>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon returned"><i class="bi bi-journal-check"></i></div>
            <h3>@Model.ReturnedBooks.ToString("N0")</h3>
            <p>Returned Books</p>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-xl-8 d-flex flex-column gap-4">
        <div class="dashboard-card">
            <div class="dashboard-card-header d-flex justify-content-between align-items-center">
                <span>System Alerts</span>
                <span class="badge bg-danger rounded-pill">@alertCount New</span>
            </div>
            <div class="dashboard-card-body">
                @if (Model.OverdueBooks > 0)
                {
                    <div class="custom-alert alert-danger-soft">
                        <i class="bi bi-exclamation-octagon-fill"></i>
                        <div>
                            <strong>Overdue Books</strong>
                            @Model.OverdueBooks student@(Model.OverdueBooks == 1 ? "" : "s") currently have overdue books.
                        </div>
                    </div>
                }
                @if (lowStockBooks.Any())
                {
                    <div class="custom-alert alert-warning-soft @(Model.OverdueBooks > 0 ? "mb-0" : "")">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <div>
                            <strong>Low Stock Warning</strong>
                            @lowStockBooks.Count title@(lowStockBooks.Count == 1 ? "" : "s") currently have 2 or fewer available copies.
                        </div>
                    </div>
                }
                @if (alertCount == 0)
                {
                    <div class="custom-alert alert-warning-soft mb-0">
                        <i class="bi bi-check-circle-fill"></i>
                        <div>
                            <strong>No active alerts</strong>
                            Inventory and overdue activity are currently clear.
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="dashboard-card">
            <div class="dashboard-card-header d-flex justify-content-between align-items-center">
                <span>Recent Activity</span>
                <a asp-controller="Admin" asp-action="TransactionHistory" class="text-decoration-none text-primary fs-6 fw-normal">View All</a>
            </div>
            <div class="dashboard-card-body">
                @if (Model.RecentTransactions.Any())
                {
                    <ul class="activity-list">
                        @foreach (var transaction in Model.RecentTransactions)
                        {
                            var book = Model.Books.FirstOrDefault(b => b.Id == transaction.BookId);
                            var user = Model.Users.FirstOrDefault(u => u.Id == transaction.UserId);
                            var isReturned = transaction.ReturnDate.HasValue;
                            <li class="activity-item">
                                <div class="activity-icon @(isReturned ? "return" : "borrow")">
                                    <i class="bi @(isReturned ? "bi-box-arrow-in-down-left" : "bi-box-arrow-up-right")"></i>
                                </div>
                                <div class="activity-content">
                                    <p><strong>@(user?.FullName ?? "Unknown user")</strong> @(isReturned ? "returned" : "borrowed") '@(book?.Title ?? "Unknown book")'</p>
                                    <span class="activity-time">@FormatRelativeTime(isReturned ? transaction.ReturnDate!.Value : transaction.BorrowDate)</span>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">No transactions yet.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-4">
        <div class="dashboard-card">
            <div class="dashboard-card-header">Quick Actions</div>
            <div class="dashboard-card-body">
                <div class="quick-actions-grid">
                    <a href="#" class="quick-action-btn" data-bs-toggle="modal" data-bs-target="#globalAddBookModal">
                        <i class="bi bi-journal-plus text-primary"></i>
                        Add New Book
                    </a>
                    <a asp-controller="Admin" asp-action="TransactionHistory" class="quick-action-btn">
                        <i class="bi bi-clock-history text-info"></i>
                        View Transactions
                    </a>
                    <a asp-controller="Admin" asp-action="ManageUsers" class="quick-action-btn">
                        <i class="bi bi-people text-success"></i>
                        Manage Users
                    </a>
                    <a asp-controller="Admin" asp-action="ManageBooks" class="quick-action-btn">
                        <i class="bi bi-bookmark-dash text-warning"></i>
                        Manage Borrowed Books
                    </a>
                    <a asp-controller="Admin" asp-action="Categories" class="quick-action-btn">
                        <i class="bi bi-tags text-secondary"></i>
                        Edit Categories
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    private static string FormatRelativeTime(DateTime date)
    {
        var elapsed = DateTime.Now - date;

        if (elapsed.TotalMinutes < 1) return "Just now";
        if (elapsed.TotalMinutes < 60) return $"{(int)elapsed.TotalMinutes} minute{((int)elapsed.TotalMinutes == 1 ? "" : "s")} ago";
        if (elapsed.TotalHours < 24) return $"{(int)elapsed.TotalHours} hour{((int)elapsed.TotalHours == 1 ? "" : "s")} ago";
        if (elapsed.TotalDays < 2) return "Yesterday";
        if (elapsed.TotalDays < 7) return $"{(int)elapsed.TotalDays} days ago";

        return date.ToString("yyyy-MM-dd");
    }
}
