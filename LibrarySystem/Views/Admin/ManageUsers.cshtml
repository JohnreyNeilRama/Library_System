@model LibrarySystem.Controllers.AdminManageUsersViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Users";

    var activeUsers = Model.Users.Count(u => u.IsActive);
    var inactiveUsers = Model.Users.Count(u => !u.IsActive);
    var newThisMonth = Model.Users.Count(u => u.CreatedAt.Year == DateTime.Now.Year && u.CreatedAt.Month == DateTime.Now.Month);
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h4 class="fw-bold mb-1">Users & Students</h4>
        <p class="text-muted mb-0 small">Manage registered users and view account status.</p>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <div class="row g-4 text-center">
            <div class="col-6 col-md-3 border-end">
                <div class="text-muted small fw-bold text-uppercase mb-1">Total Students</div>
                <h3 class="fw-bold text-dark mb-0">@Model.Users.Count</h3>
            </div>
            <div class="col-6 col-md-3 border-end">
                <div class="text-muted small fw-bold text-uppercase mb-1">Active Students</div>
                <h3 class="fw-bold text-success mb-0">@activeUsers</h3>
            </div>
            <div class="col-6 col-md-3 border-end">
                <div class="text-muted small fw-bold text-uppercase mb-1">New This Month</div>
                <h3 class="fw-bold text-primary mb-0">@newThisMonth</h3>
            </div>
            <div class="col-6 col-md-3">
                <div class="text-muted small fw-bold text-uppercase mb-1">Inactive/Banned</div>
                <h3 class="fw-bold text-danger mb-0">@inactiveUsers</h3>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="p-3 border-bottom bg-light">
            <form asp-controller="Admin" asp-action="ManageUsers" method="get" class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                <div class="input-group" style="max-width: 350px;">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" value="@Model.Search" class="form-control border-start-0 ps-0" placeholder="Search by name, email, or student ID...">
                </div>
                <button type="submit" class="btn btn-primary btn-sm">Search</button>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Student</th>
                        <th>Student ID</th>
                        <th>Course & Year</th>
                        <th>Registered Date</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users.Any())
                    {
                        foreach (var user in Model.Users.OrderByDescending(u => u.CreatedAt))
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrWhiteSpace(user.ProfilePictureUrl))
                                        {
                                            <img src="@user.ProfilePictureUrl" alt="@user.FullName" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px;">
                                                @(string.IsNullOrWhiteSpace(user.FullName) ? "U" : user.FullName.Substring(0, 1).ToUpper())
                                            </div>
                                        }
                                        <div>
                                            <div class="fw-bold text-dark">@user.FullName</div>
                                            <div class="small text-muted">@user.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-muted font-monospace small">@user.IdNumber</td>
                                <td><span class="badge bg-light text-dark border">@user.Course - @user.YearLevel</span></td>
                                <td class="text-muted small">@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>@Html.Raw(UserStatusBadge(user.IsActive))</td>
                                <td class="text-end pe-4">
                                    <a asp-controller="Admin" asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-light text-primary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-controller="Admin" asp-action="ToggleUserStatus" asp-route-id="@user.Id" class="btn btn-sm btn-light @(user.IsActive ? "text-danger" : "text-success")" title="@(user.IsActive ? "Deactivate" : "Activate")">
                                        <i class="bi @(user.IsActive ? "bi-slash-circle" : "bi-check-circle")"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">No users found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="p-3 border-top d-flex justify-content-between align-items-center text-muted small bg-white rounded-bottom">
            <div>Showing <span class="fw-medium text-dark">@Model.Users.Count</span> entries</div>
        </div>
    </div>
</div>

@functions {
    private static string UserStatusBadge(bool isActive)
    {
        return isActive
            ? "<span class=\"badge bg-success bg-opacity-10 text-success px-2 py-1\"><i class=\"bi bi-check-circle me-1\"></i>Active</span>"
            : "<span class=\"badge bg-danger bg-opacity-10 text-danger px-2 py-1\"><i class=\"bi bi-x-circle me-1\"></i>Inactive</span>";
    }
}
