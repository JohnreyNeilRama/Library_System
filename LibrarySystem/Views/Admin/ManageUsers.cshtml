@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h4 class="fw-bold mb-1">Users & Students</h4>
        <p class="text-muted mb-0 small">Manage registered users, reset passwords, and view activity.</p>
    </div>
    <div class="d-flex gap-2">

        <button class="btn btn-primary btn-sm" id="btnOpenAddUser" data-bs-toggle="modal" data-bs-target="#userProfileModal">
            <i class="bi bi-person-plus"></i> Add New User
        </button>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <div class="row g-4 text-center">
            <div class="col-6 col-md-3 border-end">
                <div class="text-muted small fw-bold text-uppercase mb-1">Total Students</div>
                <h3 class="fw-bold text-dark mb-0">1,429</h3>
            </div>
            <div class="col-6 col-md-3 border-end">
                <div class="text-muted small fw-bold text-uppercase mb-1">Active Students</div>
                <h3 class="fw-bold text-success mb-0">1,385</h3>
            </div>
            <div class="col-6 col-md-3 border-end">
                <div class="text-muted small fw-bold text-uppercase mb-1">New This Month</div>
                <h3 class="fw-bold text-primary mb-0">44</h3>
            </div>
            <div class="col-6 col-md-3">
                <div class="text-muted small fw-bold text-uppercase mb-1">Inactive/Banned</div>
                <h3 class="fw-bold text-danger mb-0">32</h3>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <!-- Search Bar -->
        <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-light">
            <div class="input-group" style="max-width: 350px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="searchUsersInput" class="form-control border-start-0 ps-0" placeholder="Search by name, email, or student ID...">
            </div>
            <div>
                <select class="form-select form-select-sm" style="min-width: 140px;" id="courseFilter">
                    <option value="">All Courses</option>
                    <option value="BSCS">BSCS</option>
                    <option value="BSIT">BSIT</option>
                    <option value="BSIS">BSIS</option>
                    <option value="BSEMC">BSEMC</option>
                </select>
            </div>
        </div>

        <!-- Table -->
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Student</th>
                        <th>Student ID</th>
                        <th>Course & Year</th>
                        <th>Registered Date</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody id="usersTableBody">
                    <!-- Populated by JS -->
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <div class="p-3 border-top d-flex justify-content-between align-items-center text-muted small bg-white rounded-bottom">
            <div>Showing <span class="fw-medium text-dark">1</span> to <span class="fw-medium text-dark">8</span> of <span class="fw-medium text-dark">1,429</span> entries</div>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                    <li class="page-item"><a class="page-link" href="#">Next</a></li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- User Profile Modal (Add/Edit/View) -->
<div class="modal fade" id="userProfileModal" tabindex="-1" aria-labelledby="userProfileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light border-bottom-0">
                <h5 class="modal-title fw-bold" id="userProfileModalLabel"><i class="bi bi-person-plus me-2 text-primary"></i>Register New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="userProfileForm">
                    <input type="hidden" id="userIdInput">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold text-uppercase">Full Name</label>
                        <input type="text" class="form-control bg-light" id="userFullNameInput" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold text-uppercase">Email Address</label>
                        <input type="email" class="form-control bg-light" id="userEmailInput" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold text-uppercase">Student ID Number</label>
                        <input type="text" class="form-control bg-light" id="userStudentIdInput" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted small fw-bold text-uppercase">Course</label>
                            <select class="form-select bg-light" id="userCourseInput">
                                <option value="BSCS">BSCS</option>
                                <option value="BSIT">BSIT</option>
                                <option value="BSIS">BSIS</option>
                                <option value="BSEMC">BSEMC</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted small fw-bold text-uppercase">Year Level</label>
                            <select class="form-select bg-light" id="userYearInput">
                                <option value="1st Year">1st Year</option>
                                <option value="2nd Year">2nd Year</option>
                                <option value="3rd Year">3rd Year</option>
                                <option value="4th Year">4th Year</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top-0 bg-light">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal" id="userModalCancelBtn">Cancel</button>
                <button type="button" class="btn btn-primary px-4" id="saveUserBtn">Save</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            
            const tableBody = document.getElementById('usersTableBody');
            const searchInput = document.getElementById('searchUsersInput');
            const courseFilter = document.getElementById('courseFilter');
            
            // Mock Data Generator
            const firstNames = ["James", "Maria", "Robert", "Linda", "John", "Elizabeth", "Michael", "Susan", "William", "Jessica"];
            const lastNames = ["Smith", "Johnson", "Williams", "Brown", "Jones", "Garcia", "Miller", "Davis", "Rodriguez", "Martinez"];
            const courses = ["BSCS", "BSIT", "BSIS", "BSEMC"];
            const yearLevels = ["1st Year", "2nd Year", "3rd Year", "4th Year"];
            
            let usersData = [];
            
            for(let i = 1; i <= 24; i++) {
                const fname = firstNames[Math.floor(Math.random() * firstNames.length)];
                const lname = lastNames[Math.floor(Math.random() * lastNames.length)];
                const course = courses[Math.floor(Math.random() * courses.length)];
                const yearLevel = yearLevels[Math.floor(Math.random() * yearLevels.length)];
                
                // Status is mostly active
                const statusChance = Math.random();
                let status = "Active";
                if(statusChance > 0.9) status = "Inactive";
                if(statusChance > 0.98) status = "Banned";
                
                // Random ID like 2024-00123
                const studentId = `2024-${String(10000 + i).padStart(5, '0')}`;
                usersData.push({
                    id: i,
                    name: `${fname} ${lname}`,
                    email: `${fname.toLowerCase()}.${lname.toLowerCase()}@@university.edu`,
                    studentId: studentId,
                    course: course,
                    yearLevel: yearLevel,
                    date: `Oct ${Math.floor(Math.random() * 28) + 1}, 2024`,
                    status: status
                });
            }

            function renderTable(users) {
                tableBody.innerHTML = '';
                users.forEach(user => {
                    // Status Badge
                    let statusBadge = '';
                    if(user.status === 'Active') statusBadge = '<span class="badge bg-success bg-opacity-10 text-success px-2 py-1"><i class="bi bi-check-circle me-1"></i>Active</span>';
                    else if(user.status === 'Inactive') statusBadge = '<span class="badge bg-secondary bg-opacity-10 text-secondary px-2 py-1"><i class="bi bi-clock me-1"></i>Inactive</span>';
                    else statusBadge = '<span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1"><i class="bi bi-x-circle me-1"></i>Banned</span>';

                    const row = `
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px;">
                                        ${user.name.charAt(0)}
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">${user.name}</div>
                                        <div class="small text-muted">${user.email}</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-muted font-monospace small">${user.studentId}</td>
                            <td><span class="badge bg-light text-dark border">${user.course} - ${user.yearLevel}</span></td>
                            <td class="text-muted small">${user.date}</td>
                            <td>${statusBadge}</td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-light text-primary view-user-btn" data-id="${user.id}" title="View Profile">
                                    <i class="bi bi-person-lines-fill"></i>
                                </button>
                                <button class="btn btn-sm btn-light text-muted edit-user-btn" data-id="${user.id}" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-light text-danger delete-btn" title="Ban/Delete">
                                    <i class="bi bi-slash-circle"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                    tableBody.innerHTML += row;
                });
            }

            // Initial render
            renderTable(usersData.slice(0, 8)); // Display first 8
            
            // Search & Filter functionality
            function filterData() {
                const term = searchInput.value.toLowerCase();
                const course = courseFilter.value;
                
                const filtered = usersData.filter(u => {
                    const matchesSearch = u.name.toLowerCase().includes(term) || 
                                          u.email.toLowerCase().includes(term) ||
                                          u.studentId.toLowerCase().includes(term);
                    const matchesCourse = course === "" || u.course === course;
                    return matchesSearch && matchesCourse;
                });
                renderTable(filtered.slice(0, 8));
            }
            
            searchInput.addEventListener('keyup', filterData);
            courseFilter.addEventListener('change', filterData);
            // Profile Modal Logic
            const userProfileModal = new bootstrap.Modal(document.getElementById('userProfileModal'));
            const userProfileForm = document.getElementById('userProfileForm');
            const saveUserBtn = document.getElementById('saveUserBtn');
            const userModalLabel = document.getElementById('userProfileModalLabel');
            
            function setFormReadOnly(isReadOnly) {
                const inputs = userProfileForm.querySelectorAll('input, select');
                inputs.forEach(input => {
                    if (input.tagName === 'SELECT') {
                        input.disabled = isReadOnly;
                    } else {
                        input.readOnly = isReadOnly;
                    }
                    if(isReadOnly) {
                        input.classList.remove('bg-light');
                        input.classList.add('bg-white');
                    } else {
                        input.classList.remove('bg-white');
                        input.classList.add('bg-light');
                    }
                });
                saveUserBtn.style.display = isReadOnly ? 'none' : 'inline-block';
                document.getElementById('userModalCancelBtn').textContent = isReadOnly ? 'Close' : 'Cancel';
            }

            // Open Add User Modal
            document.getElementById('btnOpenAddUser')?.addEventListener('click', function() {
                userProfileForm.reset();
                document.getElementById('userIdInput').value = '';
                userModalLabel.innerHTML = '<i class="bi bi-person-plus me-2 text-primary"></i>Register New Student';
                saveUserBtn.textContent = 'Register';
                setFormReadOnly(false);
            });

            // View, Edit, and Delete Buttons Action
            tableBody.addEventListener('click', function(e) {
                // View or Edit Profile
                const viewBtn = e.target.closest('.view-user-btn');
                const editBtn = e.target.closest('.edit-user-btn');
                
                if (viewBtn || editBtn) {
                    const isEdit = !!editBtn;
                    const btn = viewBtn || editBtn;
                    const userId = parseInt(btn.getAttribute('data-id'));
                    const user = usersData.find(u => u.id === userId);
                    
                    if (user) {
                        document.getElementById('userIdInput').value = user.id;
                        document.getElementById('userFullNameInput').value = user.name;
                        document.getElementById('userEmailInput').value = user.email;
                        document.getElementById('userStudentIdInput').value = user.studentId;
                        document.getElementById('userCourseInput').value = user.course;
                        document.getElementById('userYearInput').value = user.yearLevel;
                        
                        if (isEdit) {
                            userModalLabel.innerHTML = '<i class="bi bi-pencil-square me-2 text-primary"></i>Edit Student Profile';
                            saveUserBtn.textContent = 'Save Changes';
                            setFormReadOnly(false);
                        } else {
                            userModalLabel.innerHTML = '<i class="bi bi-person-badge me-2 text-primary"></i>View Student Profile';
                            setFormReadOnly(true);
                        }
                        
                        userProfileModal.show();
                    }
                }
                
                // Delete
                const deleteBtn = e.target.closest('.delete-btn');
                if (deleteBtn) {
                    if(confirm('Are you sure you want to ban/remove this user?')) {
                        deleteBtn.closest('tr').remove();
                    }
                }
            });

            // Save Action (Mockup handling updates)
            saveUserBtn.addEventListener('click', function() {
                const id = document.getElementById('userIdInput').value;
                if (id) {
                    // Update existing student in the array
                    const user = usersData.find(u => u.id == parseInt(id));
                    if (user) {
                        user.name = document.getElementById('userFullNameInput').value;
                        user.email = document.getElementById('userEmailInput').value;
                        user.studentId = document.getElementById('userStudentIdInput').value;
                        user.course = document.getElementById('userCourseInput').value;
                        user.yearLevel = document.getElementById('userYearInput').value;
                        filterData(); // Refresh table
                    }
                } else {
                    // Add new student
                    const name = document.getElementById('userFullNameInput').value;
                    if(name) {
                        usersData.unshift({
                            id: usersData.length + 100,
                            name: name,
                            email: document.getElementById('userEmailInput').value,
                            studentId: document.getElementById('userStudentIdInput').value,
                            course: document.getElementById('userCourseInput').value,
                            yearLevel: document.getElementById('userYearInput').value,
                            date: 'Just now',
                            status: 'Active'
                        });
                        filterData();
                    }
                }
                userProfileModal.hide();
            });

        });
    </script>
}
