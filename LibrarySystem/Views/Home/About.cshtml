@{
    ViewData["Title"] = "About";
}

<section class="about-hero-section">
    <div class="container">
        <div class="about-hero-content text-center">
            <h1 class="fw-bold text-white mb-4">About Library<span class="text-primary">System</span></h1>
            <p class="lead text-white-50 mb-0">Empowering communities through accessible knowledge and seamless library experiences</p>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const stats = document.querySelectorAll('.about-stat-number');
            
            stats.forEach(stat => {
                const text = stat.innerText;
                const target = parseInt(text);
                if (isNaN(target)) return;
                
                let current = 0;
                const duration = 1000; // 1 second
                const steps = 50;
                const increment = target / steps;
                const interval = duration / steps;
                
                const timer = setInterval(() => {
                    current += increment;
                    if (current >= target) {
                        stat.innerText = target;
                        clearInterval(timer);
                    } else {
                        stat.innerText = Math.floor(current);
                    }
                }, interval);
            });
        });
    </script>
}

<section class="about-section about-section-alt">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="about-info-card h-100">
                    <div class="about-icon mb-4">
                        <i class="bi bi-bullseye"></i>
                    </div>
                    <h2 class="fw-bold text-white mb-4">Our Mission</h2>
                    <p class="text-white-50 mb-0">To provide universal access to knowledge and foster a love of reading by creating an intuitive, accessible digital library platform that serves our community's diverse needs.</p>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="about-info-card h-100">
                    <div class="about-icon mb-4">
                        <i class="bi bi-globe2"></i>
                    </div>
                    <h2 class="fw-bold text-white mb-4">Our Vision</h2>
                    <p class="text-white-50 mb-0">To become a leading digital library platform that connects traditional library services with modern technology, making reading and learning accessible to everyone.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="about-section">
    <div class="container">
        <div class="about-story mx-auto">
            <h2 class="fw-bold text-white text-center mb-4">Our Story</h2>
            <p class="text-white-50">LibrarySystem was created to make library services easier, faster, and more accessible. We recognized the challenges users face when searching for books, tracking borrowed items, and managing library transactions.</p>
            <p class="text-white-50 mb-0">Our platform brings these services into one simple digital experience, helping students, readers, and library staff manage resources more conveniently.</p>
        </div>
    </div>
</section>

<section class="about-section about-section-alt">
    <div class="container">
        <h2 class="fw-bold text-white text-center mb-5">Our Core Values</h2>
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="about-value">
                    <div class="about-icon mx-auto mb-4">
                        <i class="bi bi-people"></i>
                    </div>
                    <h3 class="fw-bold text-white mb-3">Accessibility</h3>
                    <p class="text-white-50 mb-0">We believe everyone deserves simple and reliable access to library resources.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="about-value">
                    <div class="about-icon mx-auto mb-4">
                        <i class="bi bi-heart"></i>
                    </div>
                    <h3 class="fw-bold text-white mb-3">Community</h3>
                    <p class="text-white-50 mb-0">We support learning by connecting readers, books, and library services in one place.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="about-value">
                    <div class="about-icon mx-auto mb-4">
                        <i class="bi bi-award"></i>
                    </div>
                    <h3 class="fw-bold text-white mb-3">Excellence</h3>
                    <p class="text-white-50 mb-0">We continuously improve the system to provide a smooth and dependable library experience.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="about-section">
    <div class="container">
        <h2 class="fw-bold text-white text-center mb-5">By The Numbers</h2>
        <div class="row g-4 text-center">
            <div class="col-6 col-lg-3">
                <div class="about-stat">
                    <div class="about-stat-number">@(ViewBag.BookCount ?? 0)</div>
                    <p class="text-white-50 mb-0">Books</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="about-stat">
                    <div class="about-stat-number">@(ViewBag.UserCount ?? 0)</div>
                    <p class="text-white-50 mb-0">Members</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="about-stat">
                    <div class="about-stat-number">@(ViewBag.TransactionCount ?? 0)</div>
                    <p class="text-white-50 mb-0">Borrows</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="about-stat">
                    <div class="about-stat-number">@(ViewBag.CategoryCount ?? 0)</div>
                    <p class="text-white-50 mb-0">Categories</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="about-section about-section-alt">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold text-white mb-3">Frequently Asked Questions</h2>
            <p class="text-white-50 mb-0">Common questions about using our library system</p>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="accordion accordion-flush custom-accordion" id="faqAccordion">
                    <div class="accordion-item bg-transparent border-bottom border-secondary border-opacity-25">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-transparent text-white py-4 px-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                How do I borrow a book?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-white-50 px-0 pb-4">
                                Once you're registered and logged in, simply browse our collection, select a book, and click the 'Borrow' button. You'll receive a notification about the due date.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item bg-transparent border-bottom border-secondary border-opacity-25">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-transparent text-white py-4 px-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                Can I reserve a book that is currently borrowed?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-white-50 px-0 pb-4">
                                Yes! If a book is currently unavailable, you can use the 'Reserve' feature to be notified when it's returned and available for borrowing.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item bg-transparent">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-transparent text-white py-4 px-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                What is the standard borrowing period?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-white-50 px-0 pb-4">
                                Our standard borrowing period is 14 days. You can check your dashboard to see specific due dates and manage your current borrows.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

