@model LibrarySystem.Models.UserCategoryBooksViewModel

@{
    ViewData["Title"] = Model.CategoryName;
    Layout = "_UserLayout";
}

<link rel="stylesheet" href="~/css/books.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/modal.css" asp-append-version="true" />

<div class="books-under-category-container">
    <div class="page-header">
        <div class="breadcrumb-nav">
            <a asp-controller="User" asp-action="Categories">Categories</a>
            <span class="breadcrumb-separator">&#8250;</span>
            <span>@Model.CategoryName</span>
        </div>
        <h1 class="page-title">@Model.CategoryName Books</h1>
        <p class="page-subtitle">Browse and borrow books from this category</p>
    </div>

    <div class="toolbar">
        <div class="search-box">
            <span class="search-icon">&#128269;</span>
            <input type="text" id="searchInput" placeholder="Search by title or author..." />
        </div>
        <div class="filter-buttons">
            <button class="filter-btn active" data-filter="all">All (@Model.TotalBooks)</button>
            <button class="filter-btn" data-filter="available">Available (@Model.AvailableCount)</button>
            <button class="filter-btn" data-filter="unavailable">Out of Stock (@Model.UnavailableCount)</button>
        </div>
    </div>

    @if (Model?.Books != null && Model.Books.Any())
    {
        <div class="books-grid" id="booksGrid">
            @foreach (var book in Model.Books)
            {
                var isAvailable = book.AvailableCopies > 0;
                <div class="book-card"
                     data-title="@book.Title.ToLower()"
                     data-author="@book.Author.ToLower()"
                     data-availability="@(isAvailable ? "available" : "unavailable")"
                     data-book-id="@book.Id"
                     data-book-title="@book.Title"
                     data-book-author="@book.Author">
                    <div class="book-cover">
                        @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                        {
                            <img src="@book.CoverImageUrl" alt="@book.Title" />
                        }
                        else
                        {
                            <span>&#128214;</span>
                        }
                    </div>
                    <div class="book-content">
                        <h3 class="book-title" title="@book.Title">@book.Title</h3>
                        <p class="book-author">by @book.Author</p>
                        @if (!string.IsNullOrWhiteSpace(book.ISBN))
                        {
                            <p class="book-isbn">ISBN: @book.ISBN</p>
                        }
                        <div class="book-meta">
                            <div class="availability">
                                <span class="availability-dot @(isAvailable ? "available" : "unavailable")"></span>
                                <span class="availability-text">@(isAvailable ? $"{book.AvailableCopies} available" : "All copies borrowed")</span>
                            </div>
                            <span class="status-badge @(isAvailable ? "available" : "unavailable")">
                                @(isAvailable ? "Available" : "All copies borrowed")
                            </span>
                        </div>
                    </div>
                    @if (isAvailable)
                    {
                        <button type="button" class="btn-borrow available" onclick="openBorrowModalFromCard(this)">
                            Request Borrow
                        </button>
                    }
                    else
                    {
                        if (book.ReservationStatus == "Pending")
                        {
                            <div class="reservation-notice pending">
                                <span>&#9202;</span>
                                <span>Reservation pending approval</span>
                            </div>
                            <button type="button" class="btn-borrow awaiting" disabled>
                                Awaiting Approval
                            </button>
                        }
                        else if (book.ReservationStatus == "Approved")
                        {
                            <div class="reservation-notice approved">
                                <span>&#10003;</span>
                                <span>Reservation approved for claiming</span>
                            </div>
                            <button type="button" class="btn-borrow awaiting" disabled>
                                Awaiting Claim
                            </button>
                        }
                        else
                        {
                            <form asp-controller="User" asp-action="Reserve" method="post" class="reserve-form">
                                <input type="hidden" name="bookId" value="@book.Id" />
                                <input type="hidden" name="category" value="@Model.CategoryId" />
                                <button type="submit" class="btn-borrow reserve">
                                    Reserve Book
                                </button>
                            </form>
                        }
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">&#128218;</div>
            <h3>No books in this category</h3>
            <p>There are currently no books available in @Model.CategoryName. Please check back later.</p>
        </div>
    }
</div>

<!-- Borrow Modal -->
<div id="borrowModal" class="modal" role="dialog" aria-labelledby="borrowModalLabel" aria-hidden="true">
    <div class="modal-overlay"></div>
    <div class="modal-container">
        <div class="modal-header">
            <div>
                <h2 id="borrowModalLabel" class="modal-title">Confirm Borrow Request</h2>
            </div>
            <button type="button" class="modal-close" aria-label="Close modal" onclick="closeBorrowModal()">
                <span>&times;</span>
            </button>
        </div>

        <div class="modal-body">
            <p class="modal-subtitle">Please review the details before confirming.</p>

            <div id="formLoading" class="loading-state" style="display: none;">
                <div class="spinner"></div>
                <p>Processing...</p>
            </div>

            <div id="formContent">
                <div class="book-summary-card">
                    <div class="book-summary-icon">&#128214;</div>
                    <div class="book-summary-details">
                        <h4 id="modalBookTitle"></h4>
                        <p id="modalBookAuthor"></p>
                    </div>
                </div>

                <div class="borrow-details-card">
                    <div class="detail-row">
                        <span class="detail-label">Borrow Date</span>
                        <span class="detail-value fw-bold" id="borrowDateDisplay"></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">End Date</span>
                        <input type="date" name="EndDate" id="endDateInput" class="form-control form-control-sm" required />
                    </div>
                </div>

                <p class="return-note">
                    <span class="note-icon">&#9432;</span> You can choose an end date up to 14 days from today.
                </p>

                <form id="borrowForm" asp-controller="User" asp-action="Borrow" method="post">
                    <input type="hidden" name="BookId" id="bookIdInput" />
                    <input type="hidden" name="BorrowDate" id="borrowDateInput" />

                    <div class="form-actions">
                        <button type="button" class="btn-cancel" onclick="closeBorrowModal()">Cancel</button>
                        <button type="submit" class="btn-submit" id="submitBtn">
                            <span class="btn-text">Submit Request</span>
                        </button>
                    </div>
                </form>
            </div>

            <div id="successMessage" class="success-state" style="display: none;">
                <div class="success-icon">&#10004;</div>
                <h3>Borrow Request Submitted</h3>
                <p id="successText"></p>
                <button type="button" class="btn-done" onclick="closeBorrowModal()">Done</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/borrow-modal.js" asp-append-version="true"></script>
}
