@model LibrarySystem.Models.UserCategoriesViewModel
@{
    ViewData["Title"] = "Categories";
    Layout = "_UserLayout";
}

<link rel="stylesheet" href="~/css/categories.css" asp-append-version="true" />

<div class="dashboard-container">
    <div class="categories-header">
        <h1 class="page-title">Categories</h1>
        <p class="page-subtitle">Browse books by category</p>
    </div>
    <div class="category-grid">
        <div class="category-card">
            <div class="category-icon">💻</div>
            <div class="category-content">
                <h3 class="category-name">Programming</h3>
                <p class="category-count">24 books</p>
            </div>
            <a asp-controller="Books" asp-action="Index" asp-route-category="programming" class="btn-view-books">View Books</a>
        </div>
        <div class="category-card">
            <div class="category-icon">🗄️</div>
            <div class="category-content">
                <h3 class="category-name">Database</h3>
                <p class="category-count">18 books</p>
            </div>
            <a asp-controller="Books" asp-action="Index" asp-route-category="database" class="btn-view-books">View Books</a>
        </div>
        <div class="category-card">
            <div class="category-icon">🌐</div>
            <div class="category-content">
                <h3 class="category-name">Networking</h3>
                <p class="category-count">12 books</p>
            </div>
            <a asp-controller="Books" asp-action="Index" asp-route-category="networking" class="btn-view-books">View Books</a>
        </div>
        <div class="category-card">
            <div class="category-icon">🌍</div>
            <div class="category-content">
                <h3 class="category-name">Web Development</h3>
                <p class="category-count">28 books</p>
