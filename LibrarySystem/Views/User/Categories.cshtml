@model LibrarySystem.Models.UserCategoriesViewModel
@{
    ViewData["Title"] = "Categories";
    Layout = "_UserLayout";
}

<link rel="stylesheet" href="~/css/categories.css" asp-append-version="true" />

<div class="dashboard-container">
    <div class="categories-header">
        <h1 class="page-title">Categories</h1>
        <p class="page-subtitle">Browse books by category</p>
    </div>

    @if (Model.Categories.Any())
    {
        <div class="category-grid">
            @foreach (var category in Model.Categories)
            {
                <div class="category-card">
                    <div class="category-icon" aria-hidden="true">@category.Initials</div>
                    <div class="category-content">
                        <h3 class="category-name">@category.Name</h3>
                        <p class="category-count">@category.BookCount @(category.BookCount == 1 ? "book" : "books")</p>
                        @if (!string.IsNullOrWhiteSpace(category.Description))
                        {
                            <p class="category-description">@category.Description</p>
                        }
                    </div>
                    <a asp-controller="User" asp-action="Books" asp-route-category="@category.Id" class="btn-view-books">View Books</a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon" aria-hidden="true">&#128218;</div>
            <h3>No categories found</h3>
            <p>Categories will appear here once they have been added.</p>
        </div>
    }
</div>
