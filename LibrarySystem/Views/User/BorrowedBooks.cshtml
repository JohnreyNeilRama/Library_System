@model LibrarySystem.Controllers.UserBorrowedBooksViewModel

@{
    ViewData["Title"] = "My Borrowed Books";
    Layout = "_UserLayout";
}

<div class="borrowed-books-container">
    <div class="page-header">
        <h1 class="page-title">My Borrowed Books</h1>
        <p class="page-subtitle">Track your borrowed books and due dates</p>
    </div>

    @if (Model?.BorrowedBooks != null && Model.BorrowedBooks.Any())
    {
        <div class="books-grid">
            @foreach (var book in Model.BorrowedBooks)
            {
                <div class="book-card">
                    <div class="book-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                        </svg>
                    </div>
                    <div class="book-content">
                        <h3 class="book-title">@book.Title</h3>
                        <p class="book-author">@book.Author</p>
                        <div class="book-dates">
                            <div class="date-item">
                                <span class="date-label">Borrowed:</span>
                                <span class="date-value">@book.BorrowDate.ToString("MMM dd, yyyy")</span>
                            </div>
                            <div class="date-item">
                                <span class="date-label">Due:</span>
                                <span class="date-value">@book.DueDate.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                    </div>
                    <span class="status-badge">@book.Status</span>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                </svg>
            </div>
            <h3>No borrowed books</h3>
            <p>You haven't borrowed any books yet. Browse our collection to get started!</p>
        </div>
    }
</div>

<style>
        .borrowed-books-container { max-width: 1400px; margin: 0 auto; padding: 1.5rem; }
        .page-header { margin-bottom: 2rem; }
        .page-title { font-size: 1.75rem; font-weight: 700; color: #1a1a2e; margin: 0 0 0.5rem 0; }
        .page-subtitle { font-size: 1rem; color: #6b7280; margin: 0; }
        .books-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
        .book-card { background: white; border-radius: 12px; padding: 1.5rem; box-shadow: 0 2px 8px rgba(0,0,0,0.06); display: flex; flex-direction: column; gap: 1rem; transition: all 0.3s ease; }
        .book-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }
        .book-icon { width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; color: white; }
        .book-content { display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
        .book-title { font-size: 1.1rem; font-weight: 600; color: #1a1a2e; margin: 0; line-height: 1.4; }
        .book-author { font-size: 0.85rem; color: #9ca3af; margin: 0; }
        .book-dates { display: flex; flex-direction: column; gap: 0.5rem; margin-top: auto; }
        .date-item { display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; }
        .date-label { color: #9ca3af; }
        .date-value { color: #4b5563; font-weight: 500; }
        .status-badge { display: inline-flex; align-items: center; padding: 0.4rem 0.8rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.02em; align-self: flex-start; }
        .status-badge.on-time { background: #d1fae5; color: #065f46; }
        .status-badge.due-soon { background: #fef3c7; color: #92400e; }
        .status-badge.overdue { background: #fee2e2; color: #991b1b; }
        .empty-state { text-align: center; padding: 4rem 2rem; background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
        .empty-icon { width: 64px; height: 64px; border-radius: 16px; background: #f3f4f6; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; color: #9ca3af; }
        .empty-state h3 { font-size: 1.25rem; font-weight: 600; color: #1a1a2e; margin: 0 0 0.5rem 0; }
        .empty-state p { font-size: 0.95rem; color: #6b7280; margin: 0; }
        @@media (max-width: 1200px) { .books-grid { grid-template-columns: repeat(2, 1fr); } }
        @@media (max-width: 768px) { .books-grid { grid-template-columns: 1fr; } }
    </style>

